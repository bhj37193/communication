{
  "expo": {
    "name": "Charisma Trainer",
    "slug": "charisma-trainer",
    "scheme": "charisma",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#1e293b"
    },
    "plugins": [
      "expo-router",
      "expo-sharing"
    ],
    "ios": {
      "bundleIdentifier": "com.charisma.trainer",
      "supportsTablet": true
    },
    "android": {
      "package": "com.charisma.trainer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e293b"
      }
    }
  }
}
