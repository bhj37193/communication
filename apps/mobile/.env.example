EXPO_PUBLIC_API_URL=http://localhost:3001

# Set to true to use the dev-fake identity instead of Clerk (default flow in
# this repo until a real Clerk key is configured below).
EXPO_PUBLIC_DEV_FAKE_AUTH=true

# From the Clerk dashboard (API Keys page) once your Clerk app exists.
# Leave unset (or keep EXPO_PUBLIC_DEV_FAKE_AUTH=true) to stay on the dev-fake flow.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
