{
  "name": "@charisma/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:integration": "vitest run",
    "e2e:smoke": "tsx --env-file=.env test/e2e/smoke.ts",
    "smoke:anthropic": "tsx --env-file=.env scripts/smoke-anthropic.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "psql -v ON_ERROR_STOP=1 -f src/db/migrations/0000_init.sql \"$DATABASE_URL_OWNER\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@charisma/core": "workspace:*",
    "@clerk/backend": "^3.11.7",
    "@fastify/cors": "^11.3.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "pg": "^8.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
