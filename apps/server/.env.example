NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://charisma_app@localhost:5432/charisma
DATABASE_URL_OWNER=postgres://main@localhost:5432/charisma

# Provider selectors: composition.ts is the only file that reads these.
AUTH_PROVIDER=fake
MODEL_PROVIDER=fake

# Required when AUTH_PROVIDER=clerk. Get this from the Clerk dashboard
# (API Keys page) once your Clerk app exists.
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Required when MODEL_PROVIDER=anthropic.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

DAILY_MODEL_BUDGET_USD=20

# Signing secret for the Clerk webhook (Dashboard > Webhooks > Signing Secret).
# Empty -> /v1/webhooks/clerk accepts unsigned JSON bodies (fake/test mode).
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

FREE_DAILY_SCORED_LIMIT=1000
