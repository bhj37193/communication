# Copy to /opt/charisma/apps/server/.env on the VPS (chmod 600, never commit).
# Names match apps/server/src/env.ts + the two vars read directly via
# process.env (CORS_ORIGINS in src/app.ts, FREE_DAILY_SCORED_LIMIT in
# src/services/caps.ts). No real secrets below.

NODE_ENV=production
PORT=3000

# charisma_app is a passwordless (trust-auth, local-only) role created by the
# 0000_init.sql migration - see deploy/README.md for the pg_hba.conf line
# this requires.
DATABASE_URL=postgres://charisma_app@localhost:5432/charisma

# Only used once, to run the migration as the DB owner (see deploy/README.md
# step 4). The running server never reads this var.
DATABASE_URL_OWNER=postgres://postgres@localhost:5432/charisma

# KNOWN BLOCKER (see deploy/README.md): composition.ts forbids AUTH_PROVIDER=fake
# when NODE_ENV=production, but AUTH_PROVIDER=clerk has no implementation yet.
# The server will not boot in production until real Clerk auth ships.
AUTH_PROVIDER=fake

MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me
DAILY_MODEL_BUDGET_USD=20

CLERK_WEBHOOK_SECRET=replace-me

# Comma-separated allowlist of origins allowed to call this API. Only
# enforced when NODE_ENV=production (dev reflects any origin).
CORS_ORIGINS=https://yourapp.example.com

# Optional - defaults to 1 if unset.
FREE_DAILY_SCORED_LIMIT=1
