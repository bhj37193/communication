# Native Postgres 18, localhost:5432, no Docker. Owner is trust-auth superuser `main`
# (no password). The least-privilege `charisma_app` role is created by the 0000_init
# migration; DATABASE_URL switches to it once that migration has run.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://charisma_app@localhost:5432/charisma
DATABASE_URL_OWNER=postgres://main@localhost:5432/charisma
